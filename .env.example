DJANGO_SECRET_KEY=change-me
# Локальная разработка: true. Продакшен: false (см. docs/DEPLOY.md).
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# docker — в проде; local — без Docker на машине (только при DJANGO_DEBUG=true или SANDBOX_ALLOW_LOCAL_FALLBACK=true)
SANDBOX_ENGINE=docker
SANDBOX_DOCKER_IMAGE=gitplayground-sandbox:latest
# Локально без Docker: DJANGO_DEBUG=true (fallback на local) или SANDBOX_ENGINE=local

# SQLite (файл БД в корне проекта по умолчанию)
# SQLITE_DB_PATH=db.sqlite3

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
LOG_LEVEL=INFO

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=GitPlayground <noreply@example.com>

SIGNUP_REQUIRE_EMAIL_CONFIRMATION=false

# Продакшен за reverse-proxy (HTTPS):
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_HSTS_SECONDS=31536000
# После collectstatic можно отключить поиск по исходникам:
# WHITENOISE_USE_FINDERS=false
